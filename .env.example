# ============================================
# GlycoGrit Frontend - Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control
#
# Based on NOVA project patterns for enterprise-grade configuration
# ============================================

# ============================================
# APPLICATION CONFIGURATION
# ============================================

# App metadata (public variables, prefixed with VITE_)
VITE_APP_NAME=GlycoGrit
VITE_APP_DESCRIPTION="Track your fitness challenges"
VITE_APP_VERSION=1.0.0

# Environment identifier
VITE_ENVIRONMENT=development  # development | staging | production

# ============================================
# API CONFIGURATION
# ============================================

# Backend API URL (required)
VITE_API_BASE_URL=http://localhost:8000

# API timeout settings (milliseconds)
VITE_API_TIMEOUT=30000
VITE_API_RETRY_ATTEMPTS=3
VITE_API_RETRY_DELAY=1000

# ============================================
# FEATURE FLAGS
# ============================================

# Enable/disable features
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_DEBUG_MODE=false
VITE_ENABLE_TELEMETRY=false
VITE_ENABLE_SOCIAL_SHARING=false
VITE_ENABLE_NOTIFICATIONS=false

# ============================================
# FILE UPLOAD CONFIGURATION
# ============================================

# Maximum file upload limits
VITE_MAX_FILES_PER_UPLOAD=10
VITE_MAX_FILE_SIZE_MB=10
VITE_MAX_TOTAL_SIZE_MB=50

# Allowed file types (comma-separated)
VITE_ALLOWED_FILE_TYPES=jpg,jpeg,png,pdf,csv

# ============================================
# CHALLENGE CONFIGURATION
# ============================================

# Pagination settings
VITE_CHALLENGES_PER_PAGE=20
VITE_MAX_CHALLENGES_PER_PAGE=100

# Default filters
VITE_DEFAULT_CHALLENGE_CATEGORY=all
VITE_DEFAULT_CHALLENGE_DIFFICULTY=all

# ============================================
# AUTHENTICATION & SECURITY
# ============================================

# Auth token configuration
VITE_AUTH_TOKEN_KEY=glycogrit_auth_token
VITE_AUTH_REFRESH_TOKEN_KEY=glycogrit_refresh_token
VITE_SESSION_TIMEOUT_MINUTES=60

# OAuth providers
VITE_GOOGLE_CLIENT_ID=your-google-client-id-here
# VITE_FACEBOOK_APP_ID=your-facebook-app-id

# ============================================
# THIRD-PARTY INTEGRATIONS (OPTIONAL)
# ============================================

# Analytics (Google Analytics, Mixpanel, etc.)
# VITE_GA_TRACKING_ID=UA-XXXXXXXXX-X
# VITE_MIXPANEL_TOKEN=your-mixpanel-token

# Error tracking (Sentry, Rollbar, etc.)
# VITE_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
# VITE_SENTRY_ENVIRONMENT=development

# Maps integration (if showing challenge locations)
# VITE_GOOGLE_MAPS_API_KEY=your-google-maps-key
# VITE_MAPBOX_ACCESS_TOKEN=your-mapbox-token

# ============================================
# RATE LIMITING
# ============================================

# Client-side rate limiting
VITE_RATE_LIMIT_REQUESTS_PER_MINUTE=60
VITE_RATE_LIMIT_REQUESTS_PER_HOUR=1000

# ============================================
# CACHING CONFIGURATION
# ============================================

# Cache durations (milliseconds)
VITE_CACHE_CHALLENGES_DURATION=300000  # 5 minutes
VITE_CACHE_USER_PROFILE_DURATION=600000  # 10 minutes
VITE_CACHE_STATIC_DATA_DURATION=3600000  # 1 hour

# ============================================
# UI CONFIGURATION
# ============================================

# Theme settings
VITE_DEFAULT_THEME=light  # light | dark | auto
VITE_ENABLE_THEME_SWITCHING=true

# Locale/i18n
VITE_DEFAULT_LOCALE=en
VITE_SUPPORTED_LOCALES=en,es,fr

# ============================================
# PERFORMANCE & OPTIMIZATION
# ============================================

# Enable performance monitoring
VITE_ENABLE_PERFORMANCE_MONITORING=false

# Image optimization
VITE_IMAGE_QUALITY=80
VITE_IMAGE_MAX_WIDTH=1920

# Lazy loading
VITE_ENABLE_LAZY_LOADING=true

# ============================================
# DEVELOPMENT SETTINGS (LOCAL ONLY)
# ============================================

# Mock API (for development without backend)
VITE_USE_MOCK_API=false

# Debug tools
VITE_SHOW_DEV_TOOLS=false
VITE_ENABLE_REDUX_DEVTOOLS=false

# Hot module replacement
VITE_HMR_ENABLED=true

# ============================================
# SECRETS (NEVER COMMIT THESE!)
# ============================================
# These should be set in .env.local ONLY
# Add them to .gitignore patterns

# API keys and tokens
# API_SECRET_KEY=your-secret-key-here
# JWT_SECRET=your-jwt-secret-here

# Database credentials (if connecting from frontend - NOT RECOMMENDED)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=glycogrit
# DB_USER=your-db-user
# DB_PASSWORD=your-db-password

# ============================================
# CI/CD ENVIRONMENT VARIABLES
# ============================================
# These are typically set in CI/CD platform (Vercel, Netlify, etc.)

# Build configuration
# VERCEL_ENV=production
# VERCEL_GIT_COMMIT_SHA=abc123
# VERCEL_GIT_COMMIT_MESSAGE="Deploy to production"

# ============================================
# HEALTH CHECK & MONITORING
# ============================================

# Health check endpoint (for load balancers)
VITE_HEALTH_CHECK_PATH=/health

# Status page URL
VITE_STATUS_PAGE_URL=https://status.glycogrit.com

# ============================================
# NOTES
# ============================================
#
# 1. VITE_ prefix makes variables available in browser
# 2. Never put secrets in VITE_ prefixed variables
# 3. Use .env.local for local development (gitignored)
# 4. Use .env.production for production builds
# 5. Vercel/Netlify will inject environment variables at build time
#
# For more information:
# - Vite environment variables: https://vitejs.dev/guide/env-and-mode.html
# - Security best practices: /wiki/04-Security-Best-Practices.md
# ============================================
